{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "typescript/triple-slash-reference": "off"
  },
  "env": {
    "builtin": true,
    "browser": true,
    "node": true,
    "es2020": true
  },
  "ignorePatterns": ["dist", "types/src/generated"]
}
