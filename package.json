{
  "name": "peterportal",
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"pnpm --filter=api dev\" \"pnpm --filter=site dev\"",
    "prepare": "husky",
    "format": "oxfmt --write \"**/*.{css,scss,cjs,js,ts,tsx,yml,json,html}\" --no-error-on-unmatched-pattern",
    "lint": "oxfmt --check \"**/*.{css,scss,cjs,js,ts,tsx,yml,json,html}\" --no-error-on-unmatched-pattern && pnpm --filter=site lint && pnpm --filter=api lint",
    "test": "pnpm --filter=site test",
    "db:generate": "pnpm --filter=api db:generate",
    "db:migrate": "pnpm --filter=api db:migrate",
    "db:studio": "pnpm --filter=api db:studio"
  },
  "dependencies": {
    "dotenv-flow": "^4.0.1",
    "sst": "3.17.10"
  },
  "engines": {
    "node": "^18 || ^20 || ^22",
    "pnpm": "^10"
  },
  "devDependencies": {
    "@types/aws-lambda": "8.10.145",
    "@types/node": "20.12.8",
    "concurrently": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0"
  }
}
